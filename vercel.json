{
  "version": 2,
  "outputDirectory": ".",
  "buildCommand": "echo 'No build needed'",
  "functions": {
    "api/*.js": { "maxDuration": 10 }
  },
  "routes": [
    { "src": "/styles.css",         "dest": "/styles.css" },
    { "src": "/admin-styles.css",   "dest": "/admin-styles.css" },
    { "src": "/scripts.js",         "dest": "/scripts.js" },
    { "src": "/admin-scripts.js",   "dest": "/admin-scripts.js" },
    { "src": "/login",              "dest": "/login.html" },
    { "src": "/admin",              "dest": "/admin.html" },
    { "src": "/reset-password",     "dest": "/reset-password.html" },
    { "src": "/(.*)\\.html",        "dest": "/$1.html" },
    { "src": "/api/(.*)",           "dest": "/api/$1" },
    { "src": "/(.*)",               "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control",          "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
